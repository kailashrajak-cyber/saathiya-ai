# ── AI Provider ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Auth ─────────────────────────────────────────────────────
# ZAROORI: production mein isko ek random string se replace karo
# Generate karne ka tarika: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-STRING

# ── Google Sign-In (optional) ────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Agar set nahi kiya to Google button show nahi hoga — baaki sab kaam karega
GOOGLE_CLIENT_ID=

# ── Database (optional) ──────────────────────────────────────
# Default: SQLite (saathiya.db file ban jaati hai automatically)
# Production ke liye PostgreSQL recommended hai:
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=sqlite:///saathiya.db
